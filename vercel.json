{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/agents/execute-agent.js": { "maxDuration": 60 },
    "api/agents/process-conversation-event.js": { "maxDuration": 60 }
  },
  "crons": [
    {
      "path": "/api/cron/process-scheduled-messages",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/process-activity-notifications",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/process-agent-schedules",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/check-lead-absence",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/automation/process-schedules",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/sync-whatsapp-status",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/renew-credits",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/expire-trials",
      "schedule": "0 3 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/track.gif",
      "destination": "/api/track"
    },
    {
      "source": "/webhook/conversion",
      "destination": "/api/webhook"
    },
    {
      "source": "/((?!api).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/m4track.js",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/javascript"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000"
        }
      ]
    },
    {
      "source": "/m4track-v5.js",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/javascript"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}
