{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/agents/execute-agent.js": { "maxDuration": 60 },
    "api/agents/process-conversation-event.js": { "maxDuration": 60 },
    "api/leads/import-file.js": { "maxDuration": 60 },
    "api/webhook/uazapi/[company_id].js": { "maxDuration": 60 },
    "api/uazapi-webhook-final.js": { "maxDuration": 60 },
    "api/instagram/webhook.js": { "maxDuration": 30 },
    "api/instagram/comments/index.js": { "maxDuration": 15 },
    "api/instagram/comments/[commentId]/reply.js": { "maxDuration": 20 },
    "api/instagram/comments/[commentId]/hide.js": { "maxDuration": 20 },
    "api/instagram/comments/[commentId]/ignore.js": { "maxDuration": 15 },
    "api/instagram/comments/[commentId]/call-direct.js": { "maxDuration": 20 },
    "api/instagram/comments/[commentId]/create-lead.js": { "maxDuration": 20 },
    "api/instagram/deauthorize.js": { "maxDuration": 15 },
    "api/instagram/data-deletion/index.js": { "maxDuration": 30 },
    "api/instagram/data-deletion/status.js": { "maxDuration": 10 },
    "api/cron/refresh-instagram-tokens.js": { "maxDuration": 60 },
    "api/agents/process-message-buffer.js": { "maxDuration": 60 }
  },
  "crons": [
    {
      "path": "/api/cron/process-scheduled-messages",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/process-activity-notifications",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/process-agent-schedules",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/check-lead-absence",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/automation/process-schedules",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/automation/process-timeouts",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/sync-whatsapp-status",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/renew-credits",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/generate-dashboard-snapshots",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/expire-trials",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/alert-trials",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/refresh-instagram-tokens",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/agents/process-message-buffer",
      "schedule": "* * * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/track.gif",
      "destination": "/api/track"
    },
    {
      "source": "/webhook/conversion",
      "destination": "/api/webhook"
    },
    {
      "source": "/((?!api).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/m4track.js",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/javascript"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000"
        }
      ]
    },
    {
      "source": "/m4track-v5.js",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/javascript"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}
