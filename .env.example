# Configurações do Supabase para Lovoo CRM
# Você precisará substituir estes valores pelos dados reais do seu projeto Supabase

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Configurações de Produção
NODE_ENV=production
VITE_APP_NAME=Lovoo CRM
VITE_APP_VERSION=1.0.0

# =====================================================
# WHATSAPP LIFE - CONFIGURAÇÕES UAZAPI (SERVIDOR APENAS)
# =====================================================
# IMPORTANTE: Estas variáveis devem ser configuradas apenas no servidor
# Nunca expor no frontend (não usar prefixo VITE_)

# URL base da API Uazapi
UAZAPI_BASE_URL=https://lovoo.uazapi.com

# Token administrativo da Uazapi (MANTER SEGURO)
UAZAPI_ADMIN_TOKEN=your-uazapi-admin-token

# Para obter os valores do Supabase:
# 1. Acesse https://supabase.com/dashboard
# 2. Selecione seu projeto (ou crie um novo)
# 3. Vá em Settings > API
# 4. Copie a URL e a chave anon/public

# Para desenvolvimento local:
# cp .env.example .env

# =====================================================
# CRON JOB - MENSAGENS AGENDADAS
# =====================================================
# Secret para autenticar chamadas do cron job do Vercel
# Gerar com: openssl rand -base64 32
CRON_SECRET=your-random-secret-key-here

# Para produção no Vercel:
# Configure estas variáveis no dashboard do Vercel

# =====================================================
# GOOGLE CALENDAR INTEGRATION
# =====================================================
# Credenciais OAuth2 do Google Cloud Console
# Para obter:
# 1. Acesse https://console.cloud.google.com
# 2. Crie um projeto ou selecione existente
# 3. Ative a Google Calendar API
# 4. Vá em "Credentials" > "Create Credentials" > "OAuth 2.0 Client ID"
# 5. Configure Authorized redirect URIs:
#    - PROD: https://app.lovoocrm.com/api/google-calendar/auth/callback
#    - DEV: https://lovoo-dev.vercel.app/api/google-calendar/auth/callback

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# IMPORTANTE: Usar URL do ambiente correto
# PROD (app.lovoocrm.com):
GOOGLE_REDIRECT_URI=https://app.lovoocrm.com/api/google-calendar/auth/callback
GOOGLE_WEBHOOK_URL=https://app.lovoocrm.com/api/google-calendar/webhook

# DEV (lovoo-dev.vercel.app):
# GOOGLE_REDIRECT_URI=https://lovoo-dev.vercel.app/api/google-calendar/auth/callback
# GOOGLE_WEBHOOK_URL=https://lovoo-dev.vercel.app/api/google-calendar/webhook
